# HCT site frontend — Supabase read access (publishable key only; safe in browser).
# Copy to .env and fill in. The backend writes with the SECRET key; the browser
# only ever reads under RLS with the publishable key.
VITE_SB_URL=https://YOUR-PROJECT.supabase.co
VITE_SB_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
