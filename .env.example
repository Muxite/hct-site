# Copy to keys.env (gitignored) and fill in. Loaded by docker compose.

# --- LLM (the AI system that writes site data) -----------------------------
OPENROUTER_API_KEY=
# Optional: override the default LLM (Gemini 3 Flash Preview via OpenRouter).
# OPENROUTER_MODEL=google/gemini-3-flash-preview

# --- Supabase (the site's data store) --------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SB_URL=
# Frontend key — PUBLISHABLE (safe to embed in the static site; RLS-protected,
# read-only). Put this same value in frontend/hct-render/config.js.
SB_PUB_KEY=
# Backend key — SECRET (full access, bypasses RLS). Used by hct-manager to write.
# NEVER ship this to the browser.
SB_SEC_KEY=
# Legacy key pair (compatibility fallbacks if the new keys aren't available):
SB_ANON_PUB_KEY=
SB_SERVICE_ROLE_KEY=
