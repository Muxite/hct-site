# Copy to keys.env (gitignored) and fill in. Loaded by docker compose.

# --- LLM (the AI system that writes site data) -----------------------------
OPENROUTER_API_KEY=
# Optional: override the default LLM (Gemini 3 Flash Preview via OpenRouter).
# OPENROUTER_MODEL=google/gemini-3-flash-preview

# --- Sources ----------------------------------------------------------------
# Google Scholar is an optional secondary source (the CV is primary) and is
# OFF by default — scraping Scholar trips CAPTCHAs. Opt in per run:
# HCT_SCHOLAR_ENABLED=1

# --- Supabase (the site's data store) --------------------------------------
# This file configures the BACKEND (hct-manager). The frontend (React + Vite)
# has its own env — copy frontend/.env.example to frontend/.env and set
# VITE_SB_URL + VITE_SB_PUBLISHABLE_KEY (the same project URL + publishable key).
#
# Project URL, e.g. https://abcdefgh.supabase.co
SB_URL=
# Frontend key — PUBLISHABLE (safe to embed in the site; RLS-protected,
# read-only). Same value goes in frontend/.env as VITE_SB_PUBLISHABLE_KEY.
SB_PUB_KEY=
# Backend key — SECRET (full access, bypasses RLS). Used by hct-manager to write.
# NEVER ship this to the browser.
SB_SEC_KEY=
# Legacy key pair (compatibility fallbacks if the new keys aren't available):
SB_ANON_PUB_KEY=
SB_SERVICE_ROLE_KEY=
